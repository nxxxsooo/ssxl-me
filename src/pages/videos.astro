---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allVideos = await getCollection('videos');
const videos = allVideos.sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) {
        return a.data.pinned ? -1 : 1;
    }
    return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

function formatDate(date: Date) {
    return date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\//g, '.');
}
---

<Layout title="视频" description="分享思考与生活点滴的视频空间。">
    <main class="max-w-4xl mx-auto px-4 md:px-6 py-12 md:py-16 overflow-x-hidden">
        <header class="mb-24">
            <h1 class="font-serif text-4xl md:text-6xl font-light tracking-tight leading-none mb-12">视频</h1>
            
            <!-- Channel QR Card -->
            <section class="p-8 bg-stone-50 border border-stone-200 flex flex-col md:flex-row items-center gap-8">
                <img src="/images/channels-qr.jpg" alt="关注视频号" class="w-32 h-32 object-contain" width="128" height="128" />
                <div class="text-center md:text-left">
                    <h4 class="font-serif text-xl mb-2">关注视频号</h4>
                    <p class="text-stone-600 leading-relaxed">获取更多视频更新，扫码关注施施小洛的视频号。</p>
                </div>
            </section>
        </header>

        <section id="videos">
            <div class="flex items-center justify-between mb-16 border-b border-stone-200 pb-4">
                <h2 class="font-serif text-2xl uppercase tracking-widest">精选视频</h2>
                <span class="text-stone-400 text-sm">{new Date().getFullYear()}</span>
            </div>

            <div class="video-list">
                {videos.map((video) => (
                    <a href={`https://www.douyin.com/video/${video.data.douyinId}`} target="_blank" rel="noopener" class="video-item group">
                        <div class="video-item-left">
                            <div class="video-item-icon">
                                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                                    <path d="M8 5v14l11-7z"/>
                                </svg>
                            </div>
                        </div>
                        <div class="video-item-body">
                            <div class="video-item-header">
                                <h3 class="video-item-title">
                                    {video.data.pinned && <span class="video-item-pin">置顶</span>}
                                    {video.data.title}
                                </h3>
                                <time class="video-item-date" datetime={video.data.pubDate.toISOString()}>
                                    {formatDate(video.data.pubDate)}
                                </time>
                            </div>
                            <p class="video-item-desc">{video.data.description}</p>
                        </div>
                        <div class="video-item-arrow">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20">
                                <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </main>
</Layout>
