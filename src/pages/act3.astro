<script>
  // Checklist interactivity
  const checklistItems = document.querySelectorAll('.checklist-item');
  const resultBox = document.getElementById('checklist-result');
  
  const messages = {
    low: '⚠️ 你的第三幕存在结构性风险，需要针对性重写',
    medium: '📝 你的第三幕基本合格，但仍有优化空间',
    high: '✅ 恭喜！你的第三幕结构完整'
  };
  
  checklistItems.forEach(item => {
    item.addEventListener('click', () => {
      const isChecked = item.getAttribute('data-checked') === 'true';
      item.setAttribute('data-checked', (!isChecked).toString());
      item.classList.toggle('checked', !isChecked);
      updateResult();
    });
  });
  
  function updateResult() {
    const checkedCount = Array.from(checklistItems).filter(
      item => item.getAttribute('data-checked') === 'true'
    ).length;
    
    resultBox.className = 'checklist-result';
    
    if (checkedCount < 6) {
      resultBox.textContent = messages.low;
      resultBox.classList.add('result-warning');
    } else if (checkedCount < 9) {
      resultBox.textContent = messages.medium;
      resultBox.classList.add('result-ok');
    } else {
      resultBox.textContent = messages.high;
      resultBox.classList.add('result-success');
    }
  }
</script>
