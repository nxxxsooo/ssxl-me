---
import Layout from '../layouts/Layout.astro';
---

<Layout title="故事张力心电图" description="理想故事的宏观节奏——三幕结构张力曲线可视化工具">
  <main class="max-w-7xl mx-auto px-6 py-12 md:py-24">

    <!-- Header -->
    <header class="text-center mb-12">
      <h1 class="font-serif text-3xl md:text-5xl font-light tracking-tight mb-4">故事张力心电图</h1>
      <p class="text-stone-500 text-lg max-w-2xl mx-auto leading-relaxed">三幕结构下的理想叙事张力曲线——可视化你的故事节奏</p>
    </header>

    <!-- Chart Container -->
    <div class="relative w-full overflow-x-auto" id="chart-container">
      <div class="min-w-[800px]">
        <svg id="tension-chart" viewBox="0 0 1920 1080" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto" preserveAspectRatio="xMidYMid meet">
          <defs>
            <linearGradient id="tensionGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#10B981"/>
              <stop offset="35%" stop-color="#3B82F6"/>
              <stop offset="75%" stop-color="#3B82F6"/>
              <stop offset="90%" stop-color="#EF4444"/>
              <stop offset="100%" stop-color="#DC2626"/>
            </linearGradient>
            <filter id="curveShadow" x="-5%" y="-5%" width="110%" height="110%">
              <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="#000" flood-opacity="0.12"/>
            </filter>
            <filter id="pointShadow" x="-30%" y="-30%" width="160%" height="160%">
              <feDropShadow dx="1" dy="1" stdDeviation="2" flood-color="#000" flood-opacity="0.15"/>
            </filter>
            <filter id="boxShadow" x="-5%" y="-5%" width="110%" height="120%">
              <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000" flood-opacity="0.08"/>
            </filter>
          </defs>

          <!-- Background -->
          <rect width="1920" height="1080" fill="#FFFFFF"/>

          <!-- Title -->
          <text x="960" y="68" font-family="'Noto Serif SC', serif" font-size="44" font-weight="bold" fill="#111827" text-anchor="middle">【宏观节奏：故事整体的张力心电图】</text>

          <!-- Chart area: origin at (200, 110), chart 1500w x 650h -->
          <g transform="translate(200, 110)">

            <!-- Three-act background zones (interactive) -->
            <rect class="act-zone" data-act="1" x="0" y="0" width="300" height="650" fill="#EFF6FF" opacity="0.55" style="cursor:pointer"/>
            <rect class="act-zone" data-act="2" x="300" y="0" width="825" height="650" fill="#FEF3C7" opacity="0.30" style="cursor:pointer"/>
            <rect class="act-zone" data-act="3" x="1125" y="0" width="375" height="650" fill="#FEE2E2" opacity="0.55" style="cursor:pointer"/>

            <!-- Grid lines -->
            <g stroke="#F0F0F0" stroke-width="1">
              <line x1="0" y1="0" x2="1500" y2="0"/>
              <line x1="0" y1="130" x2="1500" y2="130"/>
              <line x1="0" y1="260" x2="1500" y2="260"/>
              <line x1="0" y1="390" x2="1500" y2="390"/>
              <line x1="0" y1="520" x2="1500" y2="520"/>
              <line x1="300" y1="0" x2="300" y2="650"/>
              <line x1="750" y1="0" x2="750" y2="650"/>
              <line x1="1125" y1="0" x2="1125" y2="650"/>
            </g>

            <!-- Axes -->
            <line x1="0" y1="650" x2="1520" y2="650" stroke="#1F2937" stroke-width="2.5"/>
            <line x1="0" y1="-10" x2="0" y2="650" stroke="#1F2937" stroke-width="2.5"/>
            <polygon points="1520,650 1510,644 1510,656" fill="#1F2937"/>
            <polygon points="0,-10 -6,0 6,0" fill="#1F2937"/>

            <!-- Y-axis label -->
            <text x="-70" y="325" font-family="'Inter', sans-serif" font-size="22" fill="#1F2937" transform="rotate(-90, -70, 325)" text-anchor="middle">紧张程度 ｜ 情节强度</text>

            <!-- X-axis ticks -->
            <g font-family="'Inter', sans-serif" font-size="18" fill="#6B7280" text-anchor="middle">
              <line x1="0" y1="650" x2="0" y2="662" stroke="#9CA3AF" stroke-width="1.5"/>
              <text x="0" y="685">0%</text>
              <line x1="300" y1="650" x2="300" y2="662" stroke="#9CA3AF" stroke-width="1.5"/>
              <text x="300" y="685">20%</text>
              <line x1="750" y1="650" x2="750" y2="662" stroke="#9CA3AF" stroke-width="1.5"/>
              <text x="750" y="685">50%</text>
              <line x1="1125" y1="650" x2="1125" y2="662" stroke="#9CA3AF" stroke-width="1.5"/>
              <text x="1125" y="685">75%</text>
              <line x1="1500" y1="650" x2="1500" y2="662" stroke="#9CA3AF" stroke-width="1.5"/>
              <text x="1500" y="685">100%</text>
            </g>

            <!-- Section labels -->
            <g font-family="'Noto Serif SC', serif" font-size="26" font-weight="bold" fill="#374151">
              <text x="150" y="725" text-anchor="middle">开头</text>
              <text x="712" y="725" text-anchor="middle">中段</text>
              <text x="1312" y="725" text-anchor="middle">结尾</text>
            </g>

            <!-- X-axis subtitle -->
            <text x="750" y="760" font-family="'Inter', sans-serif" font-size="18" fill="#9CA3AF" text-anchor="middle">故事主线 →</text>

            <!-- Turning Point 1 at 20% -->
            <line x1="300" y1="-10" x2="300" y2="660" stroke="#7C3AED" stroke-width="2" stroke-dasharray="6,4"/>
            <rect x="216" y="4" width="168" height="56" fill="#F5F3FF" stroke="#C4B5FD" stroke-width="1" rx="6" opacity="0.92"/>
            <text x="300" y="28" font-family="'Noto Serif SC', serif" font-size="17" font-weight="bold" fill="#6D28D9" text-anchor="middle">转折点① 20%</text>
            <text x="300" y="50" font-family="'Inter', sans-serif" font-size="15" fill="#7C3AED" text-anchor="middle">☆ 无法折返</text>

            <!-- Turning Point 2 at 75% -->
            <line x1="1125" y1="-10" x2="1125" y2="660" stroke="#7C3AED" stroke-width="2" stroke-dasharray="6,4"/>
            <rect x="1041" y="4" width="168" height="56" fill="#F5F3FF" stroke="#C4B5FD" stroke-width="1" rx="6" opacity="0.92"/>
            <text x="1125" y="28" font-family="'Noto Serif SC', serif" font-size="17" font-weight="bold" fill="#6D28D9" text-anchor="middle">转折点② 75%</text>
            <text x="1125" y="50" font-family="'Inter', sans-serif" font-size="15" fill="#7C3AED" text-anchor="middle">☆ 导向结尾</text>

            <!-- ========== TENSION CURVE ========== -->
            <path d="M 0,582 L 150,496 L 225,539 L 300,462 L 450,325 L 525,411 L 600,280 L 675,360 L 750,160 L 825,300 L 900,240 L 1000,550 L 1125,350 L 1200,154 L 1310,34 L 1400,188 L 1500,325" fill="none" stroke="url(#tensionGradient)" stroke-width="5" stroke-linejoin="round" stroke-linecap="round" filter="url(#curveShadow)"/>

            <!-- ========== DATA POINT MARKERS ========== -->
            <g filter="url(#pointShadow)">
              <!-- Red triangles at PEAKS -->
              <polygon class="data-point" data-index="1" points="150,486 139,508 161,508" fill="#DC2626" stroke="#B91C1C" stroke-width="1.5" style="cursor:pointer"/>
              <polygon class="data-point" data-index="4" points="450,315 439,337 461,337" fill="#DC2626" stroke="#B91C1C" stroke-width="1.5" style="cursor:pointer"/>
              <polygon class="data-point" data-index="6" points="600,270 589,292 611,292" fill="#DC2626" stroke="#B91C1C" stroke-width="1.5" style="cursor:pointer"/>
              <polygon class="data-point" data-index="8" points="750,150 739,172 761,172" fill="#DC2626" stroke="#B91C1C" stroke-width="1.5" style="cursor:pointer"/>
              <polygon class="data-point" data-index="10" points="900,230 889,252 911,252" fill="#DC2626" stroke="#B91C1C" stroke-width="1.5" style="cursor:pointer"/>
              <!-- Climax triangle — larger -->
              <polygon class="data-point" data-index="14" points="1310,20 1296,48 1324,48" fill="#DC2626" stroke="#B91C1C" stroke-width="2" style="cursor:pointer"/>

              <!-- Blue circles at VALLEYS -->
              <circle class="data-point" data-index="2" cx="225" cy="539" r="10" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5" style="cursor:pointer"/>
              <circle class="data-point" data-index="5" cx="525" cy="411" r="10" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5" style="cursor:pointer"/>
              <circle class="data-point" data-index="7" cx="675" cy="360" r="10" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5" style="cursor:pointer"/>
              <circle class="data-point" data-index="9" cx="825" cy="300" r="10" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5" style="cursor:pointer"/>
              <circle class="data-point" data-index="11" cx="1000" cy="550" r="10" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5" style="cursor:pointer"/>
              <circle class="data-point" data-index="13" cx="1200" cy="154" r="10" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5" style="cursor:pointer"/>
              <circle class="data-point" data-index="15" cx="1400" cy="188" r="10" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5" style="cursor:pointer"/>

              <!-- Climax glow ring -->
              <circle cx="1310" cy="34" r="24" fill="none" stroke="#DC2626" stroke-width="2" opacity="0.25"/>
            </g>

            <!-- Hit areas for start/turning/end points (invisible larger targets) -->
            <circle class="data-point" data-index="0" cx="0" cy="582" r="14" fill="transparent" style="cursor:pointer"/>
            <circle class="data-point" data-index="3" cx="300" cy="462" r="14" fill="transparent" style="cursor:pointer"/>
            <circle class="data-point" data-index="12" cx="1125" cy="350" r="14" fill="transparent" style="cursor:pointer"/>
            <circle class="data-point" data-index="16" cx="1500" cy="325" r="14" fill="transparent" style="cursor:pointer"/>

            <!-- ========== ANNOTATIONS ========== -->
            <rect x="668" y="116" width="164" height="32" fill="#EFF6FF" stroke="#93C5FD" stroke-width="1" rx="6" opacity="0.92"/>
            <text x="750" y="139" font-family="'Noto Serif SC', serif" font-size="17" font-weight="bold" fill="#1E40AF" text-anchor="middle">中点：第二幕高峰</text>

            <rect x="910" y="556" width="180" height="34" fill="#FEF3C7" stroke="#F59E0B" stroke-width="1" rx="6" opacity="0.92"/>
            <text x="1000" y="580" font-family="'Noto Serif SC', serif" font-size="18" font-weight="bold" fill="#92400E" text-anchor="middle">一无所有时刻</text>

            <rect x="1345" y="6" width="148" height="60" fill="#FEF2F2" stroke="#FECACA" stroke-width="1" rx="8" filter="url(#boxShadow)"/>
            <text x="1419" y="32" font-family="'Noto Serif SC', serif" font-size="22" font-weight="bold" fill="#DC2626" text-anchor="middle">▲ 高潮</text>
            <text x="1419" y="56" font-family="'Inter', sans-serif" font-size="17" fill="#DC2626" text-anchor="middle">冲击结尾</text>
            <line x1="1345" y1="36" x2="1330" y2="36" stroke="#DC2626" stroke-width="1.5"/>
            <polygon points="1330,36 1338,32 1338,40" fill="#DC2626"/>

          </g>

          <!-- Legend -->
          <g transform="translate(200, 905)">
            <rect x="-15" y="-28" width="580" height="70" fill="#F9FAFB" stroke="#E5E7EB" stroke-width="1" rx="10" filter="url(#boxShadow)"/>
            <text x="8" y="6" font-family="'Noto Serif SC', serif" font-size="22" font-weight="bold" fill="#1F2937">图例</text>
            <polygon points="90,-4 78,18 102,18" fill="#DC2626" stroke="#B91C1C" stroke-width="1.5"/>
            <text x="114" y="16" font-family="'Inter', sans-serif" font-size="20" fill="#374151">挫折、阻碍、问题</text>
            <circle cx="350" cy="6" r="9" fill="#2563EB" stroke="#1D4ED8" stroke-width="1.5"/>
            <text x="370" y="16" font-family="'Inter', sans-serif" font-size="20" fill="#374151">推进动作场景</text>
          </g>

          <!-- Info Box -->
          <g transform="translate(1080, 905)">
            <rect x="-15" y="-28" width="650" height="70" fill="#F9FAFB" stroke="#E5E7EB" stroke-width="1" rx="10" filter="url(#boxShadow)"/>
            <text x="8" y="2" font-family="'Noto Serif SC', serif" font-size="22" font-weight="bold" fill="#1F2937">理想张力曲线特征</text>
            <text x="8" y="30" font-family="'Inter', sans-serif" font-size="18" fill="#4B5563">① 明确上升趋势　② 丰富起伏变化　③ 高峰在 75-85%　④ 适当回落坡度</text>
          </g>

          <!-- Branding -->
          <text x="1880" y="1065" font-family="'Inter', sans-serif" font-size="14" fill="#D1D5DB" text-anchor="end">© 施施小洛 ssxl.me</text>
        </svg>
      </div>

      <!-- Tooltip -->
      <div id="tooltip" class="fixed pointer-events-none opacity-0 transition-opacity duration-150 z-50" style="will-change: transform;">
        <div class="bg-white border border-stone-200 rounded-lg shadow-lg px-5 py-4 max-w-xs">
          <div class="flex items-center gap-2 mb-1.5">
            <span id="tooltip-badge" class="text-xs font-medium px-2 py-0.5 rounded-full"></span>
            <span id="tooltip-pct" class="text-xs text-stone-400 font-mono"></span>
          </div>
          <p id="tooltip-label" class="font-serif text-base font-semibold text-stone-800 mb-1"></p>
          <p id="tooltip-desc" class="text-sm text-stone-500 leading-relaxed"></p>
        </div>
      </div>
    </div>

    <!-- Mobile hint -->
    <p class="md:hidden text-center text-stone-400 text-sm mt-3">← 横向滑动查看完整图表 →</p>

    <!-- Download Buttons -->
    <div class="flex justify-center gap-4 mt-8">
      <button id="download-svg" class="border border-brand-text px-6 py-2.5 uppercase tracking-widest text-xs font-medium hover:bg-brand-coral hover:border-brand-coral hover:text-white transition-all duration-300">
        下载 SVG
      </button>
      <button id="download-png" class="border border-brand-text px-6 py-2.5 uppercase tracking-widest text-xs font-medium hover:bg-brand-coral hover:border-brand-coral hover:text-white transition-all duration-300">
        下载 PNG
      </button>
    </div>

    <!-- Explanatory Section -->
    <section class="max-w-4xl mx-auto mt-20">
      <h2 class="font-serif text-2xl md:text-3xl text-center mb-10 font-light">如何阅读这张图？</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg p-6 shadow-sm border border-stone-200">
          <div class="text-2xl mb-3">🎭</div>
          <h3 class="font-serif text-lg font-semibold mb-2">三幕结构</h3>
          <p class="text-stone-600 text-sm leading-relaxed">开头建立世界观、中段层层发展、结尾走向高潮——这是最经典的故事骨架。转折点在 20% 和 75% 处将三幕自然分割。</p>
        </div>
        <div class="bg-white rounded-lg p-6 shadow-sm border border-stone-200">
          <div class="text-2xl mb-3">⚡</div>
          <h3 class="font-serif text-lg font-semibold mb-2">锯齿起伏</h3>
          <p class="text-stone-600 text-sm leading-relaxed">好故事不是一路上升，而是在挫折<span class="text-red-600 font-medium">△</span>和推进<span class="text-blue-600 font-medium">●</span>之间不断交替，形成张力的「呼吸感」。</p>
        </div>
        <div class="bg-white rounded-lg p-6 shadow-sm border border-stone-200">
          <div class="text-2xl mb-3">🌑</div>
          <h3 class="font-serif text-lg font-semibold mb-2">一无所有时刻</h3>
          <p class="text-stone-600 text-sm leading-relaxed">高潮前的最深低谷。让读者以为一切完了——然后绝地反击。没有这个低谷，高潮就缺少对比和冲击力。</p>
        </div>
      </div>
    </section>

    <!-- Source credit -->
    <p class="text-center text-stone-300 text-xs mt-16 mb-8">基于经典三幕结构理论 · 施施小洛制图</p>

  </main>
</Layout>

<script>
  const dataPoints = [
    { x: 0, y: 582, pct: "0%", type: "start", label: "故事开端", desc: "建立世界观和角色" },
    { x: 150, y: 496, pct: "10%", type: "peak", label: "初始冲突", desc: "第一个小挫折或矛盾" },
    { x: 225, y: 539, pct: "15%", type: "valley", label: "推进场景", desc: "角色应对，故事向前推进" },
    { x: 300, y: 462, pct: "20%", type: "turning", label: "转折点 ①", desc: "无法折返的关键节点——故事正式起航" },
    { x: 450, y: 325, pct: "30%", type: "peak", label: "升级冲突", desc: "更大的阻碍出现，张力攀升" },
    { x: 525, y: 411, pct: "35%", type: "valley", label: "推进场景", desc: "角色的应对与成长" },
    { x: 600, y: 280, pct: "40%", type: "peak", label: "新挑战", desc: "故事层层递进，困难不断升级" },
    { x: 675, y: 360, pct: "45%", type: "valley", label: "推进场景", desc: "短暂喘息与准备" },
    { x: 750, y: 160, pct: "50%", type: "midpoint", label: "中点：第二幕高峰", desc: "故事中段的最高张力点，一切加速" },
    { x: 825, y: 300, pct: "55%", type: "valley", label: "反转开始", desc: "局势开始恶化，主角陷入困境" },
    { x: 900, y: 240, pct: "60%", type: "peak", label: "最后挣扎", desc: "角色做出最后努力" },
    { x: 1000, y: 550, pct: "67%", type: "allislost", label: "一无所有时刻", desc: "最黑暗的低谷，似乎一切都完了" },
    { x: 1125, y: 350, pct: "75%", type: "turning", label: "转折点 ②", desc: "导向结尾的关键转折——柳暗花明" },
    { x: 1200, y: 154, pct: "80%", type: "valley", label: "急速上升", desc: "向高潮全力冲刺" },
    { x: 1310, y: 34, pct: "87%", type: "climax", label: "▲ 高潮", desc: "全篇最高张力——一切在此爆发" },
    { x: 1400, y: 188, pct: "93%", type: "valley", label: "下降回落", desc: "紧张程度开始缓和" },
    { x: 1500, y: 325, pct: "100%", type: "end", label: "结局", desc: "故事的收束与余韵" },
  ];

  const badgeStyles: Record<string, { bg: string; text: string; label: string }> = {
    start:     { bg: "#F3F4F6", text: "#374151", label: "起点" },
    peak:      { bg: "#FEE2E2", text: "#DC2626", label: "挫折 △" },
    valley:    { bg: "#DBEAFE", text: "#2563EB", label: "推进 ●" },
    turning:   { bg: "#EDE9FE", text: "#7C3AED", label: "转折 ☆" },
    midpoint:  { bg: "#DBEAFE", text: "#1E40AF", label: "中点" },
    allislost: { bg: "#FEF3C7", text: "#92400E", label: "低谷" },
    climax:    { bg: "#FEE2E2", text: "#DC2626", label: "高潮 ★" },
    end:       { bg: "#F3F4F6", text: "#374151", label: "终点" },
  };

  // Tooltip elements
  const tooltip = document.getElementById("tooltip")!;
  const tooltipLabel = document.getElementById("tooltip-label")!;
  const tooltipDesc = document.getElementById("tooltip-desc")!;
  const tooltipBadge = document.getElementById("tooltip-badge")!;
  const tooltipPct = document.getElementById("tooltip-pct")!;

  // Data point hover tooltips
  const points = document.querySelectorAll<SVGElement>(".data-point");
  points.forEach((el) => {
    const idx = parseInt(el.dataset.index || "0", 10);
    const d = dataPoints[idx];
    if (!d) return;

    el.addEventListener("mouseenter", () => {
      const badge = badgeStyles[d.type] || badgeStyles.start;
      tooltipLabel.textContent = d.label;
      tooltipDesc.textContent = d.desc;
      tooltipPct.textContent = d.pct;
      tooltipBadge.textContent = badge.label;
      tooltipBadge.style.backgroundColor = badge.bg;
      tooltipBadge.style.color = badge.text;
      tooltip.classList.remove("opacity-0");
      tooltip.classList.add("opacity-100");
      el.style.transform = "scale(1.35)";
      el.style.transformOrigin = "center";
      el.style.transition = "transform 0.15s ease";
    });

    el.addEventListener("mouseleave", () => {
      tooltip.classList.remove("opacity-100");
      tooltip.classList.add("opacity-0");
      el.style.transform = "scale(1)";
    });

    el.addEventListener("mousemove", (e: MouseEvent) => {
      const pad = 16;
      let x = e.clientX + pad;
      let y = e.clientY + pad;
      const rect = tooltip.getBoundingClientRect();
      if (x + rect.width > window.innerWidth) x = e.clientX - rect.width - pad;
      if (y + rect.height > window.innerHeight) y = e.clientY - rect.height - pad;
      tooltip.style.left = x + "px";
      tooltip.style.top = y + "px";
    });
  });

  // Act zone highlighting
  const zones = document.querySelectorAll<SVGRectElement>(".act-zone");
  const actOriginalOpacity: Record<string, string> = { "1": "0.55", "2": "0.30", "3": "0.55" };

  zones.forEach((zone) => {
    zone.addEventListener("mouseenter", () => {
      const activeAct = zone.dataset.act;
      zones.forEach((z) => {
        z.style.transition = "opacity 0.25s ease";
        if (z.dataset.act === activeAct) {
          z.style.opacity = z.dataset.act === "2" ? "0.50" : "0.75";
        } else {
          z.style.opacity = "0.08";
        }
      });
    });
    zone.addEventListener("mouseleave", () => {
      zones.forEach((z) => {
        z.style.transition = "opacity 0.25s ease";
        z.style.opacity = actOriginalOpacity[z.dataset.act || "1"];
      });
    });
  });

  // Download SVG
  document.getElementById("download-svg")!.addEventListener("click", () => {
    const svg = document.getElementById("tension-chart")!;
    const clone = svg.cloneNode(true) as SVGElement;
    // Remove interactive attributes
    clone.querySelectorAll("[style]").forEach((el) => el.removeAttribute("style"));
    clone.querySelectorAll(".data-point").forEach((el) => el.classList.remove("data-point"));
    clone.querySelectorAll(".act-zone").forEach((el) => el.classList.remove("act-zone"));

    const serializer = new XMLSerializer();
    let source = '<?xml version="1.0" encoding="UTF-8" standalone="no"?>\n' + serializer.serializeToString(clone);

    const blob = new Blob([source], { type: "image/svg+xml;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "故事张力心电图.svg";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });

  // Download PNG
  document.getElementById("download-png")!.addEventListener("click", () => {
    const svg = document.getElementById("tension-chart")!;
    const serializer = new XMLSerializer();
    const source = serializer.serializeToString(svg);
    const blob = new Blob([source], { type: "image/svg+xml;charset=utf-8" });
    const url = URL.createObjectURL(blob);

    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement("canvas");
      canvas.width = 1920;
      canvas.height = 1080;
      const ctx = canvas.getContext("2d")!;
      ctx.fillStyle = "#FFFFFF";
      ctx.fillRect(0, 0, 1920, 1080);
      ctx.drawImage(img, 0, 0, 1920, 1080);
      canvas.toBlob((pngBlob) => {
        if (!pngBlob) return;
        const pngUrl = URL.createObjectURL(pngBlob);
        const a = document.createElement("a");
        a.href = pngUrl;
        a.download = "故事张力心电图.png";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(pngUrl);
      }, "image/png");
      URL.revokeObjectURL(url);
    };
    img.onerror = () => {
      alert("生成 PNG 时出错，请尝试使用 SVG 下载");
      URL.revokeObjectURL(url);
    };
    img.src = url;
  });
</script>
